    return Counter(items)

print(freq_count('banana'))

# 5) Validate parentheses (balanced brackets)
def is_valid_parentheses(s: str) -> bool:
    pairs = {')': '(', ']': '[', '}': '{'}
    stack = []
    for ch in s:
        if ch in '([{':
            stack.append(ch)
        elif ch in pairs:
            if not stack or stack[-1] != pairs[ch]:
                return False
            stack.pop()
        else:
            # If interviews include other chars, decide policy
            pass
    return not stack

tests = ['()', '([])', '(]', '([)]', '{[()]}', '']
for t in tests:
    print(t, '->', is_valid_parentheses(t))








# If you get: ModuleNotFoundError: No module named 'sklearn'
# Install with: pip install scikit-learn

import numpy as np

from sklearn.datasets import make_classification
from sklearn.model_selection import train_test_split

# Metrics (classification)
from sklearn.metrics import (
    accuracy_score,
    precision_score,
    recall_score,
    f1_score,
    roc_auc_score,
    confusion_matrix,
    classification_report,
)

# Preprocessing + models
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LogisticRegression

# Reproducibility
RANDOM_STATE = 42

# Create a small synthetic binary classification dataset (no external files needed)
X, y = make_classification(
    n_samples=1200,
    n_features=20,
    n_informative=8,
    n_redundant=2,
    n_classes=2,
    class_sep=1.2,
    random_state=RANDOM_STATE,
)

# Train/test split
# stratify=y keeps class ratios similar in train/test
X_train, X_test, y_train, y_test = train_test_split(
    X, y,
    test_size=0.2,
    random_state=RANDOM_STATE,
    stratify=y,
)

X_train.shape, X_test.shape


# 1) Scaling + Logistic Regression (a common baseline)
# - Logistic Regression is sensitive to feature scaling
# - Pipeline ensures the scaler is fit ONLY on training data

clf = Pipeline(
    steps=[
        ('scaler', StandardScaler()),
        ('model', LogisticRegression(max_iter=2000, random_state=RANDOM_STATE)),
    ]
)

# Fit (training)
clf.fit(X_train, y_train)

# Predict labels + probabilities
y_pred = clf.predict(X_test)
# For ROC-AUC we typically want probability of positive class (class 1)
y_proba = clf.predict_proba(X_test)[:, 1]

# Evaluate
print('accuracy :', round(accuracy_score(y_test, y_pred), 4))
print('precision:', round(precision_score(y_test, y_pred), 4))
print('recall   :', round(recall_score(y_test, y_pred), 4))
print('f1       :', round(f1_score(y_test, y_pred), 4))
print('roc_auc  :', round(roc_auc_score(y_test, y_proba), 4))

print('\nconfusion_matrix:\n', confusion_matrix(y_test, y_pred))
print('\nclassification_report:\n', classification_report(y_test, y_pred))

# Predict on "new" samples (here we just take first 5 test rows)
new_samples = X_test[:5]
print('new predicted labels:', clf.predict(new_samples).tolist())
print('new predicted probs :', np.round(clf.predict_proba(new_samples)[:, 1], 3).tolist())


# 2) Hyperparameter tuning with GridSearchCV
# In interviews, explain what you tune and why.
# - For LogisticRegression: C controls regularization strength
# - Smaller C => stronger regularization

from sklearn.model_selection import GridSearchCV, StratifiedKFold

param_grid = {
    # Note: parameters are referenced as <step_name>__<param>
    'model__C': [0.01, 0.1, 1.0, 10.0],
    'model__penalty': ['l2'],
    'model__solver': ['liblinear'],
}

cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=RANDOM_STATE)

search = GridSearchCV(
    estimator=clf,
    param_grid=param_grid,
    scoring='f1',        # choose metric based on problem (imbalanced -> F1 often better than accuracy)
    cv=cv,
    n_jobs=-1,
    refit=True,          # refit best model on the full training set
)

search.fit(X_train, y_train)

print('best_params:', search.best_params_)
print('best_cv_f1 :', round(search.best_score_, 4))

best_model = search.best_estimator_

# Final evaluation on test set (holdout)
y_pred_best = best_model.predict(X_test)
y_proba_best = best_model.predict_proba(X_test)[:, 1]

print('\nTEST metrics (best model):')
print('f1     :', round(f1_score(y_test, y_pred_best), 4))
print('roc_auc:', round(roc_auc_score(y_test, y_proba_best), 4))


# 3) Other "standard" models and when scaling matters

from sklearn.svm import SVC
from sklearn.ensemble import RandomForestClassifier

# SVMs are VERY sensitive to scaling, so use a pipeline with StandardScaler
svm_clf = Pipeline(
    steps=[
        ('scaler', StandardScaler()),
        ('model', SVC(kernel='rbf', C=1.0, gamma='scale', probability=True, random_state=RANDOM_STATE)),
    ]
)

svm_clf.fit(X_train, y_train)
svm_pred = svm_clf.predict(X_test)
svm_proba = svm_clf.predict_proba(X_test)[:, 1]
print('SVM f1:', round(f1_score(y_test, svm_pred), 4), 'roc_auc:', round(roc_auc_score(y_test, svm_proba), 4))

# Tree models (RandomForest, XGBoost, etc.) typically do NOT require scaling
rf = RandomForestClassifier(
    n_estimators=300,
    max_depth=None,
    random_state=RANDOM_STATE,
    n_jobs=-1,
)

rf.fit(X_train, y_train)
rf_pred = rf.predict(X_test)
rf_proba = rf.predict_proba(X_test)[:, 1]
print('RF  f1:', round(f1_score(y_test, rf_pred), 4), 'roc_auc:', round(roc_auc_score(y_test, rf_proba), 4))

# In interviews: be ready to explain bias/variance and why you’d pick each model.
# - Logistic Regression: strong baseline, interpretable
# - SVM: strong on medium datasets with good separation, needs scaling
# - RandomForest: handles non-linearities, robust, less preprocessing





import pandas as pd

# Two small tables with intentional mismatches and duplicates
customers = pd.DataFrame(
    {
        'customer_id': [1, 2, 3, 4],
        'name': ['Ada', 'Alan', 'Grace', 'Linus'],
        'country': ['US', 'UK', 'US', 'FI'],
    }
)

orders = pd.DataFrame(
    {
        'order_id': [101, 102, 103, 104, 105],
        'customer_id': [1, 2, 2, 99, 3],  # 99 does not exist in customers
        'amount': [120.0, 50.0, 75.0, 999.0, 200.0],
        'order_ts': pd.to_datetime(
            ['2026-01-10', '2026-01-11', '2026-01-13', '2026-01-12', '2026-01-12']
        ),
    }
)

customers, orders


# 1) Joins (pd.merge)

# INNER JOIN: only matching keys (customer_id exists in both)
inner = pd.merge(customers, orders, on='customer_id', how='inner')
print('INNER rows:', len(inner))
inner

# LEFT JOIN: keep ALL customers, match orders when possible
left = pd.merge(customers, orders, on='customer_id', how='left')
print('LEFT rows:', len(left))
left

# OUTER JOIN: keep both sides, with NaNs where missing
outer = pd.merge(
    customers,
    orders,
    on='customer_id',
    how='outer',
    indicator=True,  # adds a column showing where the row came from
)
outer


# 2) Join debugging: validate expectations
# validate helps catch mistakes like accidental many-to-many joins.

# Here: each customer_id in customers is unique, but orders has duplicates for customer_id=2
# This is a typical one-to-many join: customers (1) -> orders (many)
validated = pd.merge(
    customers,
    orders,
    on='customer_id',
    how='inner',
    validate='one_to_many',
)
validated


# 3) drop_duplicates basics

# Make a table with duplicate rows (same customer_id + amount)
dups = pd.DataFrame(
    {
        'customer_id': [1, 1, 2, 2, 2],
        'amount': [10, 10, 50, 50, 75],
        'order_ts': pd.to_datetime(['2026-01-01', '2026-01-01', '2026-01-02', '2026-01-02', '2026-01-03']),
    }
)

print('Original:')
print(dups)

print('\nDrop fully duplicated rows:')
print(dups.drop_duplicates())

print('\nDrop duplicates by subset (customer_id, amount):')
print(dups.drop_duplicates(subset=['customer_id', 'amount'], keep='first'))


# 4) "Keep latest" pattern: sort then drop_duplicates
# Common interview task: for each customer, keep the most recent order.

latest_per_customer = (
    dups.sort_values(['customer_id', 'order_ts'])
        .drop_duplicates(subset=['customer_id'], keep='last')
        .reset_index(drop=True)
)

latest_per_customer

# Alternative approach (also common): groupby + idxmax
idx = dups.groupby('customer_id')['order_ts'].idxmax()
latest_alt = dups.loc[idx].sort_values('customer_id').reset_index(drop=True)
latest_alt
